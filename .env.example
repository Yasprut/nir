# NIR - IAM Routing Microservice
# Скопируйте в .env и при необходимости измените значения

# PostgreSQL
POSTGRES_USER=nir
POSTGRES_PASSWORD=nir
POSTGRES_DB=nir

# IAM gRPC-сервер
SERVER_ADDRESS=:50051
DATABASE_URL=postgres://nir:nir@postgres:5432/nir?sslmode=disable
LOG_LEVEL=info          # info | debug
MIGRATIONS_DIR=/app/migrations
